{
  "name": "marque",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @marque/web dev",
    "dev:broker": "pnpm --filter @marque/broker dev",
    "build": "pnpm -r --filter=./apps/* --filter=./packages/* build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,sol}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,sol}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "prettier-plugin-solidity": "^1.4.1",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "viem": "2.50.4"
    }
  }
}
